  {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
      "translate",
      "target_language"
    ],
    "properties": {
      "translate": {
        "type": "boolean"
      },
      "ollama_model": {
        "type": "string"
      },
      "target_language": {
        "type": "string",
        "minLength": 1
      },
      "source_language": {
        "type": "string"
      },
      "api_key": {
        "type": "string"
      },
      "provider": {
        "type": "string",
        "enum": [
          "openai",
          "ollama"
        ]
      },
      "ollama_server": {
        "type": "string"
      },
      "prompt": {
        "type": "array"
      }
    },
    "additionalProperties": false
  }
