  {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
      "translate"
    ],
    "properties": {
      "translate": {
        "type": "boolean"
      },
      "ollama_model": {
        "type": "string"
      },
      "target_language": {
        "type": "string",
        "minLength": 1
      },
      "source_language": {
        "type": "string"
      },
      "api_key": {
        "type": "string"
      },
      "provider": {
        "type": "string",
        "enum": [
          "openai",
          "ollama"
        ]
      },
      "whisper_model": {
        "type": "string",
        "enum": [
          "tiny.en",
          "tiny",
          "base.en",
          "base",
          "small.en",
          "small",
          "medium.en",
          "medium",
          "large-v1",
          "large-v2",
          "large-v3",
          "large",
          "large-v3-turbo",
          "turbo"
        ]
      },
      "ollama_server": {
        "type": "string"
      },
      "prompt": {
        "type": "array"
      }
    },
    "additionalProperties": false
  }
